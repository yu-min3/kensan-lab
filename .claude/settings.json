{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Grep",
      "Glob",
      "Bash(kubectl get:*)",
      "Bash(kubectl describe:*)",
      "Bash(kubectl logs:*)",
      "Bash(kubectl top:*)",
      "Bash(kubectl explain:*)",
      "Bash(kubectl api-resources:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git rm:*)",
      "Bash(git mv:*)",
      "Bash(git rev-parse:*)",
      "Bash(argocd app get:*)",
      "Bash(argocd app list:*)",
      "Bash(argocd app diff:*)",
      "Bash(argocd app history:*)",
      "Bash(argocd app logs:*)",
      "Bash(argocd app manifests:*)",
      "Bash(argocd app resources:*)",
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(which:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -r:*)",
      "Bash(rmdir:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(git checkout -f:*)",
      "Bash(git rebase:*)",
      "Bash(git merge:*)",
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(scp:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(fdisk:*)",
      "Bash(kill:*)",
      "Bash(killall:*)",
      "Bash(pkill:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/.git/config)",
      "Read(**/*credentials*)",
      "Read(**/temp/*-raw.yaml)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git checkout:*)",
      "Bash(git branch -d:*)",
      "Bash(git stash:*)",
      "Bash(kubectl apply:*)",
      "Bash(kubectl delete:*)",
      "Bash(kubectl scale:*)",
      "Bash(kubectl set:*)",
      "Bash(kubectl label:*)",
      "Bash(kubectl annotate:*)",
      "Bash(kubectl patch:*)",
      "Bash(helm install:*)",
      "Bash(helm upgrade:*)",
      "Bash(helm uninstall:*)",
      "Bash(docker:*)",
      "Bash(podman:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr close:*)",
      "Bash(gh issue create:*)",
      "Bash(gh issue close:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "input=$(cat); cmd=$(echo \"$input\" | jq -r '.tool_input.command // empty' 2>/dev/null) || exit 0; if echo \"$cmd\" | grep -qE 'kubectl.*(apply|delete|patch|replace|edit|scale|set|label|annotate)' && echo \"$cmd\" | grep -qE '(-n|--namespace[= ])\\s*(kube-system|argocd|istio-system|monitoring|cert-manager)'; then echo 'BLOCKED: Direct mutation of protected namespace (kube-system, argocd, istio-system, monitoring, cert-manager). Use GitOps workflow instead.' >&2; exit 2; fi"
          }
        ]
      }
    ]
  }
}
