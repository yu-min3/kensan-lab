{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Grep",
      "Glob",
      "WebFetch",
      "WebSearch",
      "TodoWrite",
      "Task",
      "mcp__*",

      "Bash(kubectl get:*)",
      "Bash(kubectl describe:*)",
      "Bash(kubectl logs:*)",
      "Bash(kubectl kustomize:*)",
      "Bash(kubectl top:*)",
      "Bash(kubectl config:*)",
      "Bash(kubectl explain:*)",
      "Bash(kubectl api-resources:*)",
      "Bash(helm:*)",
      "Bash(kubeseal:*)",
      "Bash(podman:*)",
      "Bash(gh:*)",
      "Bash(curl:*)",

      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git fetch:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git rm:*)",
      "Bash(git mv:*)",
      "Bash(git worktree:*)",
      "Bash(git show:*)",
      "Bash(git rev-parse:*)",
      "Bash(git remote:*)",

      "Bash(npm:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)",
      "Bash(node:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(go:*)",
      "Bash(cargo:*)",
      "Bash(make:*)",
      "Bash(uv:*)",
      "Bash(mise:*)",

      "Bash(ls:*)",
      "Bash(cd:*)",
      "Bash(pwd:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(chmod:*)",
      "Bash(diff:*)",
      "Bash(tree:*)",
      "Bash(which:*)",
      "Bash(env:*)",
      "Bash(export:*)",
      "Bash(source:*)",
      "Bash(du:*)",
      "Bash(ping:*)",
      "Bash(dig:*)",
      "Bash(nslookup:*)",
      "Bash(host:*)",
      "Bash(nc:*)",
      "Bash(ssh:*)",
      "Bash(test:*)",
      "Bash(xargs:*)",
      "Bash(top:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -r:*)",
      "Bash(rmdir:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(git checkout -f:*)",
      "Bash(git rebase:*)",
      "Bash(git merge:*)",
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(wget:*)",
      "Bash(scp:*)",
      "Bash(rsync:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(fdisk:*)",
      "Bash(kill:*)",
      "Bash(killall:*)",
      "Bash(pkill:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/.git/config)",
      "Read(**/*credentials*)",
      "Read(**/temp/*-raw.yaml)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git checkout:*)",
      "Bash(git branch -d:*)",
      "Bash(git stash:*)",
      "Bash(kubectl apply:*)",
      "Bash(kubectl delete:*)",
      "Bash(kubectl exec:*)",
      "Bash(kubectl scale:*)",
      "Bash(kubectl set:*)",
      "Bash(kubectl label:*)",
      "Bash(kubectl annotate:*)",
      "Bash(kubectl patch:*)",
      "Bash(docker:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "input=$(cat); cmd=$(echo \"$input\" | jq -r '.tool_input.command // empty' 2>/dev/null) || exit 0; if echo \"$cmd\" | grep -qE 'kubectl.*(apply|delete|patch|replace|edit|scale|set|label|annotate)' && echo \"$cmd\" | grep -qE '(-n|--namespace[= ])\\s*(kube-system|argocd|istio-system|monitoring|cert-manager)'; then echo 'BLOCKED: Direct mutation of protected namespace (kube-system, argocd, istio-system, monitoring, cert-manager). Use GitOps workflow instead.' >&2; exit 2; fi"
          }
        ]
      }
    ]
  }
}