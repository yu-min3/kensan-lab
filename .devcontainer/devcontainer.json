{
    "name": "k8s develop",
    // Use pre-built image for fast startup (rebuild with: podman build -t k8s-devcontainer:stable -f .devcontainer/Dockerfile .devcontainer/)
    "image": "k8s-devcontainer:stable",
    // Uncomment below to rebuild on startup (slower)
    // "build": {
    //     "dockerfile": "Dockerfile"
    // },
    "runArgs": [
        "--userns=keep-id",
        "--privileged"
    ],
    "containerUser": "vscode", // イメージ内に存在する非ルートユーザー
    "remoteUser": "vscode",
    "postCreateCommand": "bash -c 'pip3 install --break-system-packages mkdocs-techdocs-core==1.4.0 && sudo ln -sf /home/vscode/.local/bin/mkdocs /usr/local/bin/mkdocs'",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-kubernetes-tools.vscode-kubernetes-tools",
                "redhat.vscode-yaml",
                "ms-azuretools.vscode-docker",
                "bluebrown.yamlfmt"
            ]
        }
    }
}