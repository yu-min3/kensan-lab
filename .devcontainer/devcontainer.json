{
    "name": "k8s develop",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "runArgs": [
        "--userns=keep-id",
        "--privileged"
    ],
    "containerUser": "root", // イメージ内に存在する非ルートユーザー
    "remoteUser": "root",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-kubernetes-tools.vscode-kubernetes-tools",
                "redhat.vscode-yaml",
                "ms-azuretools.vscode-docker",
                "bluebrown.yamlfmt"
            ]
        }
    }
}