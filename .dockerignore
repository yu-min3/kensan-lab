# This .dockerignore is for building Backstage Docker image
# Build context is the parent directory (kensan-lab/)
# We need to exclude everything except backstage-app/

# Exclude infrastructure (Kubernetes manifests not needed in image)
infrastructure

# Exclude docs (not needed in image)
docs
my_docs

# Exclude temp files
temp

# Exclude node_modules (CRITICAL for reducing context size)
backstage-app/node_modules
backstage-app/packages/*/node_modules

# Git and version control
.git
.gitignore

# IDE files
.vscode
.idea

# OS files
.DS_Store
Thumbs.db
