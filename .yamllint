---
# yamllint configuration for Kubernetes style
extends: default

# Helm chart の Go template は YAML として parse できないため除外
ignore: |
  charts/*/templates/
  kubernetes/secrets/*/chart/templates/
  kubernetes/network/gateway-api/gateway-api-crds.yaml

rules:
  # 実態は「シーケンスをインデントする」スタイルが主流のため強制しない
  # (旧設定 indent-sequences: false は実 manifest と乖離しており CI 未適用だった)
  indentation:
    spaces: 2
    indent-sequences: whatever
    check-multi-line-strings: false

  # `{ }` 内の空白は style として許容 (values.yaml の flow mapping で多用)
  braces:
    max-spaces-inside: 1

  # Line length is disabled for Kubernetes manifests (often auto-generated)
  line-length: disable

  # Allow multiple documents in one file (common in Kubernetes)
  document-start: disable

  # Allow empty values (common in Kubernetes)
  empty-values:
    forbid-in-block-mappings: false
    forbid-in-flow-mappings: false

  # Comments can be anywhere
  comments:
    min-spaces-from-content: 1

  # Allow trailing spaces in comments
  trailing-spaces: disable

  # Truthy values (yes/no, on/off, etc.) are OK
  truthy:
    allowed-values: ['true', 'false', 'yes', 'no', 'on', 'off']
