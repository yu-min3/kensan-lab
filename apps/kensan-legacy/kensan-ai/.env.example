# Kensan AI Configuration
# Copy this file to .env and fill in your values

# Database (individual components - used by Docker)
DB_HOST=localhost
DB_PORT=5432
DB_USER=kensan
DB_PASSWORD=kensan
DB_NAME=kensan

# Or use a single DATABASE_URL (takes precedence if set)
# DATABASE_URL=postgresql://kensan:kensan@localhost:5432/kensan

# Google Gemini API (required)
AI_PROVIDER=google
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_MODEL=gemini-2.0-flash

# Embedding (Gemini)
EMBEDDING_PROVIDER=gemini
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Cloudflare R2 Storage (required for file storage features)
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY=your-r2-access-key
R2_SECRET_KEY=your-r2-secret-key
R2_BUCKET=kensan-files

# JWT Secret (for verifying tokens from user-service)
JWT_SECRET=dev-secret-key-change-in-production

# Server
SERVER_PORT=8089
SERVER_ENV=development
HOST=0.0.0.0
DEBUG=false

# Agent settings
DEFAULT_MAX_TURNS=10
DEFAULT_TEMPERATURE=0.7
