# Kensan Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# Frontend
# =============================================================================

# MSW (Mock Service Worker) - enabled by default in DEV mode
# Set to 'false' to disable MSW and use real backend
# VITE_ENABLE_MSW=false

# Backend service URLs (used when MSW is disabled)
VITE_USER_SERVICE_URL=http://localhost:8081
VITE_TASK_SERVICE_URL=http://localhost:8082
VITE_SYNC_SERVICE_URL=http://localhost:8083
VITE_TIMEBLOCK_SERVICE_URL=http://localhost:8084
VITE_ROUTINE_SERVICE_URL=http://localhost:8085
VITE_RECORD_SERVICE_URL=http://localhost:8086
VITE_DIARY_SERVICE_URL=http://localhost:8087
VITE_ANALYTICS_SERVICE_URL=http://localhost:8088
VITE_AI_SERVICE_URL=http://localhost:8089

# =============================================================================
# Backend (used by docker-compose)
# =============================================================================

# Authentication
JWT_SECRET=dev-secret-key-change-in-production

# Google Gemini API (for AI service)
AI_PROVIDER=google
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# Clockify API (for time tracking sync) - stored per-user in DB, not needed here
