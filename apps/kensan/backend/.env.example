# Kensan Backend Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# Database
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=kensan
DB_PASSWORD=kensan
DB_NAME=kensan

# =============================================================================
# Server
# =============================================================================
SERVER_ENV=development

# =============================================================================
# Authentication
# =============================================================================
JWT_SECRET=dev-secret-key-change-in-production

# =============================================================================
# Third-party API Keys (Optional - features work without these)
# =============================================================================

# Clockify API (for time tracking sync)
# Get your API key at: https://app.clockify.me/user/settings
CLOCKIFY_API_KEY=
CLOCKIFY_WORKSPACE_ID=
