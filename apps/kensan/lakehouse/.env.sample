# =============================================================================
# Lakehouse Environment Variables
# Docker Compose (Dagster) 用。ローカル実行時はデフォルト値で動作する。
# cp .env.sample .env で作成
# =============================================================================

# --- Nessie Iceberg Catalog ---
NESSIE_URI=http://kensan-nessie:19120/iceberg/

# --- S3 (MinIO) ---
S3_ENDPOINT=http://kensan-minio:9000
S3_ACCESS_KEY=kensan
S3_SECRET_KEY=kensan-minio
S3_BUCKET=kensan-lakehouse

# --- PostgreSQL (App DB - Bronze ingest source) ---
PG_HOST=kensan-postgres
PG_PORT=5432
PG_USER=kensan
PG_PASSWORD=kensan
PG_DATABASE=kensan
