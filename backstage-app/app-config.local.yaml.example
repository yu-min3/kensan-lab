# Backstage override configuration for your local development environment
# Copy this file to app-config.local.yaml and fill in your values

# For local development, we can use the GITHUB_GHCR_PAT as GITHUB_TOKEN
integrations:
  github:
    - host: github.com
      token: ${GITHUB_GHCR_PAT}  # Set this in your environment or .env file

# Use in-memory SQLite for testing/development
# This provides a fast, ephemeral database for local development
backend:
  database:
    client: better-sqlite3
    connection: ':memory:'

# Disable permission framework for local development
permission:
  enabled: false

# Enable guest authentication for local development
auth:
  providers:
    guest:
      dangerouslyAllowOutsideDevelopment: true
