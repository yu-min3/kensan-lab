{
  "$schema": "kensan-design-tokens@1",
  "version": "1.0.0-whetstone",
  "name": "kensan-lab — Whetstone (AB-1)",
  "modes": ["light", "dark"],

  "color": {
    "light": {
      "background":       { "hsl": "40 27% 94%",  "hex": "#F5F2EC" },
      "foreground":       { "hsl": "36 11% 9%",   "hex": "#1A1714" },
      "card":             { "hsl": "40 38% 98%",  "hex": "#FCFAF6" },
      "muted":            { "hsl": "40 22% 90%",  "hex": "#E8E2D2" },
      "muted-foreground": { "hsl": "32 8% 45%",   "hex": "#7A736A" },
      "border":           { "hsl": "36 23% 85%",  "hex": "#E3DED1" },
      "border-strong":    { "hsl": "36 23% 78%",  "hex": "#D2C9B5" },
      "brand":            { "hsl": "199 89% 40%", "hex": "#0284C7" },
      "brand-muted":      { "hsl": "199 70% 92%", "hex": "#E0F1F8" },
      "accent":           { "hsl": "199 70% 92%", "hex": "#E0F1F8" },
      "accent-foreground":{ "hsl": "199 89% 25%", "hex": "#075985" },
      "success":          { "hsl": "145 40% 36%", "hex": "#377A50" },
      "warning":          { "hsl": "32 80% 45%",  "hex": "#C97516" },
      "destructive":      { "hsl": "4 70% 48%",   "hex": "#CC3925" }
    },
    "dark": {
      "background":       { "hsl": "30 10% 13%",  "hex": "#26221D" },
      "foreground":       { "hsl": "40 27% 94%",  "hex": "#F5F2EC" },
      "card":             { "hsl": "30 10% 16%",  "hex": "#2E2A23" },
      "muted":            { "hsl": "30 10% 18%",  "hex": "#332E27" },
      "muted-foreground": { "hsl": "30 8% 66%",   "hex": "#AFA89E" },
      "border":           { "hsl": "30 10% 24%",  "hex": "#443E34" },
      "border-strong":    { "hsl": "30 10% 32%",  "hex": "#5B5345" },
      "brand":            { "hsl": "199 89% 60%", "hex": "#38BDF8" },
      "brand-muted":      { "hsl": "199 40% 25%", "hex": "#26475A" },
      "accent":           { "hsl": "199 40% 22%", "hex": "#22404F" },
      "accent-foreground":{ "hsl": "199 89% 80%", "hex": "#9FD8F5" },
      "success":          { "hsl": "145 45% 52%", "hex": "#52B077" },
      "warning":          { "hsl": "32 90% 62%",  "hex": "#F1A53C" },
      "destructive":      { "hsl": "4 65% 52%",   "hex": "#D34030" }
    }
  },

  "typography": {
    "font-sans":  "\"Inter\", \"Hiragino Sans\", \"Noto Sans JP\", system-ui, sans-serif",
    "font-serif": "\"Noto Serif JP\", \"Hiragino Mincho ProN\", \"Yu Mincho\", serif",
    "font-mono":  "\"JetBrains Mono\", \"SF Mono\", ui-monospace, Menlo, monospace",
    "usage": {
      "serif": "Major headings (h1/h2), section titles, key numerics where editorial weight is wanted",
      "sans":  "Body, all UI labels, buttons, dense table content",
      "mono":  "Code, timestamps, IDs, anything tabular-numeric"
    }
  },

  "radius": {
    "base": "0.5rem",
    "sm":   "calc(var(--radius) - 4px)",
    "md":   "calc(var(--radius) - 2px)",
    "lg":   "var(--radius)",
    "xl":   "calc(var(--radius) + 4px)",
    "2xl":  "calc(var(--radius) + 8px)"
  },

  "shadow": {
    "xs":    "0 1px 2px 0 hsl(30 20% 10% / 0.05)",
    "sm":    "0 1px 3px 0 hsl(30 20% 10% / 0.08), 0 1px 2px -1px hsl(30 20% 10% / 0.04)",
    "md":    "0 4px 8px -2px hsl(30 20% 10% / 0.10), 0 2px 4px -2px hsl(30 20% 10% / 0.04)",
    "lg":    "0 10px 20px -3px hsl(30 20% 10% / 0.12), 0 4px 6px -4px hsl(30 20% 10% / 0.06)",
    "focus": "0 0 0 3px hsl(var(--brand) / 0.35)"
  },

  "motion": {
    "duration-fast":  "120ms",
    "duration-base":  "200ms",
    "duration-slow":  "320ms",
    "ease-out":       "cubic-bezier(0.16, 1, 0.3, 1)",
    "ease-in-out":    "cubic-bezier(0.4, 0, 0.2, 1)",
    "ease-spring":    "cubic-bezier(0.34, 1.56, 0.64, 1)"
  },

  "spacing": {
    "scale": "Tailwind default 4px grid (0.25rem step). Use the framework's spacing utilities — do not invent custom spacing values.",
    "_note": "Density rhythm below mirrors the [data-density] vars in tokens.css. tokens.css is the source of truth; keep these in sync (no generator yet).",
    "density": {
      "comfortable": {
        "row-h": "2.75rem", "control-h": "2.25rem",
        "card-pad-y": "1.25rem", "card-pad-x": "1.5rem",
        "section-gap": "1.5rem", "page-pad": "2rem"
      },
      "compact": {
        "row-h": "2rem", "control-h": "1.875rem",
        "card-pad-y": "0.75rem", "card-pad-x": "1rem",
        "section-gap": "1rem", "page-pad": "1.25rem"
      }
    }
  }
}
